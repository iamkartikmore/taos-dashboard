{
  "name": "taos-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"node server.js\" \"npm --prefix client run dev\"",
    "build": "npm --prefix client run build",
    "start": "NODE_ENV=production node server.js",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
